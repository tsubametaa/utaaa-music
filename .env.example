# Environment Variables Template untuk Music Sheet Builder
# Copy file ini ke .env dan sesuaikan dengan kebutuhan Anda

# Spring Boot Configuration
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# Database Configuration (H2)
SPRING_DATASOURCE_URL=jdbc:h2:file:/app/data/musicsheet
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.h2.Driver
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# H2 Console (set true untuk development, false untuk production)
SPRING_H2_CONSOLE_ENABLED=false

# Logging Level
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_UTAAA=DEBUG

# JVM Options
JAVA_OPTS=-Xms256m -Xmx512m -XX:+UseG1GC -XX:MaxGCPauseMillis=200

# Application Info
APP_NAME=Utaaa Music Sheet Builder
APP_VERSION=1.0.0
